downloaded_files/
*.lock
test_whoscored.py
verify_dash.py

# ── Logs ───────────────────────────────────────────────────────────────────
Data/**/*log*.txt

# ── Live-update pipeline state (update.py change-detection) ─────────────────
#    Tracked so the daily GitHub Action's change-detection survives between runs
#    (no rebuild + no commit on days with no new results).
# Data/simulated/.update_state.json

# ── Raw upstream data NOT consumed by the train→simulate→build pipeline ─────
#    (kept locally; training_df.csv / final_elo.csv are the processed derivatives
#     the model actually trains on, and those ARE committed)
Data/data/raw/results.csv
Data/data/processed/elo_matches.csv
Data/data/processed/monte_carlo_runs/
Data/matches_1930_2022.csv
Data/world_cup.csv

# ── StatsBomb WC22 event cache (150 MB, re-fetched by backtest_goldenball.py) ──
Data/scraped/_wc22_events_cache/

# ── Intermediate scraper byproducts (regenerated by the scrapers) ──────────
Data/scraped/raw_matches.csv
Data/scraped/team_overall_agg.csv
Data/scraped/team_tournament_agg.csv

